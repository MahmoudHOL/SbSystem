{
  "name": "conver-lang-sb-pos",
  "version": "1.0.0",
  "description": "SB Smart - Login & conver_lang",
  "main": "electron-main.js",
  "author": "SB Smart",
  "scripts": {
    "start": "node server.js",
    "dev": "node server.js",
    "electron": "electron .",
    "build": "node scripts/png-to-ico.js && electron-builder --win",
    "build:dir": "node scripts/png-to-ico.js && electron-builder --win --dir",
    "build:server-exe": "pkg server.js --targets node18-win-x64 --output dist/sb-server.exe",
    "build:server-setup": "build-server-setup.bat"
  },
  "engines": {
    "node": ">=16.0.0"
  },
  "build": {
    "appId": "com.sbsmart.pos",
    "productName": "SB Smart",
    "directories": {
      "output": "dist"
    },
    "files": [
      "**/*",
      "!**/node_modules/*/{CHANGELOG.md,README.md,README,readme.md,readme}",
      "!**/node_modules/*/{test,__tests__,tests,powered-test,example,examples}",
      "!**/*.map"
    ],
    "extraResources": [],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "build/icon.ico",
      "uninstallerIcon": "build/icon.ico",
      "installerHeaderIcon": "build/icon.ico",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "SB Smart"
    }
  },
  "dependencies": {
    "@fortawesome/fontawesome-free": "^7.2.0",
    "@whiskeysockets/baileys": "^7.0.0-rc.9",
    "bcryptjs": "^2.4.3",
    "bootstrap": "^5.3.8",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-session": "^1.17.3",
    "multer": "^2.1.1",
    "mysql2": "^3.6.5",
    "pino": "9.14.0",
    "qrcode": "^1.5.4"
  },
  "overrides": {
    "pino": "9.14.0"
  },
  "pkg": {
    "assets": [
      "public/**/*",
      "public/**/*.html",
      "public/**/*.css",
      "public/**/*.js",
      "node_modules/@whiskeysockets/baileys/**/*",
      "node_modules/bootstrap/dist/**/*",
      "node_modules/@fortawesome/fontawesome-free/**/*"
    ]
  },
  "devDependencies": {
    "electron": "^40.6.1",
    "electron-builder": "^26.8.1",
    "pkg": "^5.8.1",
    "sharp": "^0.34.5",
    "to-ico": "^1.1.5"
  }
}
